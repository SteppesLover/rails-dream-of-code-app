<h2><%= "#{@current_trimester.term} - #{@current_trimester.year}" %></h2>
<ul>

<% @current_trimester.courses.each do |course| %>
  <li>
    <%= link_to course_path(course) do %>
      <%= course.coding_class.title %>
      (<%= Enrollment.where(course_id: course.id).count %> students)
    <% end %>
  </li>
<% end %>
<h2><%= "#{@upcoming_trimester.term} - #{@upcoming_trimester.year}" %></h2>
<ul>

 <% @upcoming_trimester.courses.each do |course| %>
  <li>
    <%= link_to course_path(course) do %>
      <%= course.coding_class.title %>
      (<%= Enrollment.where(course_id: course.id).count %> students)
    <% end %>
  </li>
<% end %>
</ul>

<%= form_with url: "/dashboard", method: :post do |form| %>
  <div class="my-5">
    <%= form.label :student_name, "Student Name" %>
    <%= form.select :student, Student.all.map { |s| ["#{s.first_name} #{s.last_name}", s.id] }, {}, class: "form-control" %>
  </div>
<% end %>